{
  "id": "demo",
  "title": "Demo Control Screen",
  "description": "Basic demonstration of widget types and EPICS PV integration",
  "widgets": [
    {
      "id": "motor_x_pos",
      "type": "text_entry",
      "label": "Motor X Position",
      "data_type": "double",
      "protocol": {
        "type": "epics-pva",
        "pv_name": "demo:motor:x",
        "server": {
          "alarm_serverity": "MAJOR",
          "alarm_status": "DEVICE",
          "metadata": {
            "display": {
              "limit_low": 0.0,
              "limit_high": 100.0,
              "description": "Horizontal stage position",
              "precision": 2,
              "units": "mm"
            },
            "control": {
              "limit_low": 0.0,
              "limit_high": 120.0,
              "min_step": 0.0
            },
            "alarm": {
              "low_alarm_limit": -90.0,
              "low_warning_limit": -80.0,
              "high_alarm_limit": 90.0,
              "high_warning_limit": 80.0,
              "low_alarm_severity": "MAJOR",
              "low_warning_severity": "MINOR",
              "high_warning_severity": "MINOR",
              "high_alarm_severity": "MAJOR",
              "hysteresis": 1
            }
          }
        }
      }
    },
    {
      "id": "motor_x_pos_readback",
      "type": "text_update",
      "label": "Motor X Position Readback",
      "data_type": "double",
      "protocol": { "type": "epics-pva", "pv_name": "demo:motor:x" }
    },
    {
      "id": "motor_x_pos_readback_2",
      "type": "text_update",
      "label": "Motor X Position Readback 2",
      "data_type": "double",
      "protocol": { "type": "epics-pva", "pv_name": "demo:motor:x" }
    }
  ]
}
