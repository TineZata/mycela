{
  "id": "demo",
  "title": "Widget Showcase",
  "description": "Live light & dark theme preview of every widget type",
  "widgets": [
    {
      "id": "motor_group",
      "type": "group",
      "label": "Motor Control",
      "level": 1,
      "description": "Position entry, readback and gauge",
      "children": [
        {
          "id": "text_entry_dark",
          "pv_name": "demo:double",
          "type": "text_entry",
          "label": "Motor X Position",
          "data_type": "double",
          "description": "Editable numeric field with live alarm feedback",
          "style": { "width": "100%", "height": "auto" },
          "server": {
            "alarm_serverity": "NONE",
            "alarm_status": "NO_ALARM",
            "metadata": {
              "display": {
                "limit_low": 0.0,
                "limit_high": 100.0,
                "description": "Horizontal stage position",
                "precision": 3,
                "units": "mm"
              },
              "control": {
                "limit_low": 0.0,
                "limit_high": 100.0,
                "min_step": 0.1
              },
              "alarm": {
                "low_alarm_limit": 5.0,
                "low_warning_limit": 10.0,
                "high_warning_limit": 85.0,
                "high_alarm_limit": 95.0,
                "low_alarm_severity": "MAJOR",
                "low_warning_severity": "MINOR",
                "high_warning_severity": "MINOR",
                "high_alarm_severity": "MAJOR",
                "hysteresis": 1
              }
            }
          }
        },
        {
          "id": "text_entry_light",
          "pv_name": "demo:double",
          "type": "text_entry",
          "label": "Motor X Position",
          "data_type": "double",
          "description": "Editable numeric field with live alarm feedback",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "text_update_dark",
          "pv_name": "demo:double",
          "type": "text_update",
          "label": "Motor X Readback",
          "data_type": "double",
          "description": "Read-only live value display",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "text_update_light",
          "pv_name": "demo:double",
          "type": "text_update",
          "label": "Motor X Readback",
          "data_type": "double",
          "description": "Read-only live value display",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "gauge_dark",
          "pv_name": "demo:double",
          "type": "gauge",
          "label": "Motor X Position",
          "data_type": "double",
          "description": "Analogue bar gauge with alarm zones",
          "orientation": "horizontal",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "gauge_light",
          "pv_name": "demo:double",
          "type": "gauge",
          "label": "Motor X Position",
          "data_type": "double",
          "description": "Analogue bar gauge with alarm zones",
          "orientation": "vertical",
          "style": { "width": "100%", "height": "auto" }
        }
      ]
    },
    {
      "id": "flow_group",
      "type": "group",
      "label": "Flow Control",
      "level": 1,
      "description": "Slider and select controls",
      "children": [
        {
          "id": "slider_dark",
          "pv_name": "demo:slider",
          "type": "slider",
          "label": "Valve Position",
          "data_type": "int32",
          "description": "Drag range control with live setpoint",
          "style": { "width": "100%", "height": "auto" },
          "server": {
            "alarm_serverity": "NONE",
            "alarm_status": "NO_ALARM",
            "metadata": {
              "display": {
                "limit_low": 0,
                "limit_high": 100,
                "description": "Flow control valve aperture",
                "precision": 0,
                "units": "%"
              },
              "control": {
                "limit_low": 0,
                "limit_high": 100,
                "min_step": 1
              },
              "alarm": {
                "low_alarm_limit": 10,
                "low_warning_limit": 25,
                "high_warning_limit": 75,
                "high_alarm_limit": 90,
                "low_alarm_severity": "MINOR",
                "low_warning_severity": "MINOR",
                "high_warning_severity": "MINOR",
                "high_alarm_severity": "MAJOR",
                "hysteresis": 0
              }
            }
          }
        },
        {
          "id": "slider_light",
          "pv_name": "demo:slider",
          "type": "slider",
          "label": "Valve Position",
          "data_type": "int32",
          "description": "Drag range control with live setpoint",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "select_dark",
          "pv_name": "demo:mode:select",
          "type": "select",
          "label": "Operating Mode",
          "data_type": "enum",
          "description": "Enum dropdown backed by NTEnum PV",
          "style": { "width": "100%", "height": "30px" },
          "options": ["Off", "Manual", "Auto", "Remote"],
          "server": {
            "alarm_serverity": "NONE",
            "alarm_status": "NO_ALARM"
          }
        },
        {
          "id": "select_light",
          "pv_name": "demo:mode:select",
          "type": "select",
          "label": "Operating Mode",
          "data_type": "enum",
          "description": "Enum dropdown backed by NTEnum PV",
          "style": { "width": "100%", "height": "30px" },
          "options": ["Off", "Manual", "Auto", "Remote"]
        }
      ]
    },
    {
      "id": "interlock_group",
      "type": "group",
      "label": "Interlock System",
      "level": 1,
      "description": "Button, toggle, and LED controls",
      "children": [
        {
          "id": "button_dark",
          "pv_name": "demo:heater:cmd",
          "type": "button",
          "label": "Heater On",
          "data_type": "bool",
          "description": "Momentary action button — sends value 1 on click",
          "style": { "width": "100%", "height": "auto" },
          "server": {
            "alarm_serverity": "NONE",
            "alarm_status": "NO_ALARM"
          }
        },
        {
          "id": "button_light",
          "pv_name": "demo:heater:cmd",
          "type": "button",
          "label": "Heater On",
          "data_type": "bool",
          "description": "Momentary action button — sends value 1 on click",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "led_dark",
          "pv_name": "demo:heater:cmd",
          "type": "led",
          "label": "Heater Status",
          "data_type": "bool",
          "description": "Binary on/off indicator with glow effect",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "led_light",
          "pv_name": "demo:heater:cmd",
          "type": "led",
          "label": "Heater Status",
          "data_type": "bool",
          "description": "Binary on/off indicator with glow effect",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "toggle_button_dark",
          "pv_name": "demo:heater:cmd",
          "type": "toggle_button",
          "label": "Heater",
          "data_type": "bool",
          "description": "Toggle button — reflects live PV state and sends the opposite value on click",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "toggle_button_light",
          "pv_name": "demo:heater:cmd",
          "type": "toggle_button",
          "label": "Heater",
          "data_type": "bool",
          "description": "Toggle button — reflects live PV state and sends the opposite value on click",
          "style": { "width": "100%", "height": "auto" }
        }
      ]
    },
    {
      "id": "monitoring_group",
      "type": "group",
      "label": "Monitoring",
      "level": 1,
      "description": "Time-series charts",
      "children": [
        {
          "id": "chart_dark",
          "pv_name": "demo:temp:sensor",
          "type": "chart",
          "label": "Temperature History",
          "data_type": "double",
          "description": "Scrolling time-series chart",
          "style": { "width": "100%", "height": "auto" }
        },
        {
          "id": "chart_light",
          "pv_name": "demo:temp:sensor",
          "type": "chart",
          "label": "Temperature History",
          "data_type": "double",
          "description": "Scrolling time-series chart",
          "style": { "width": "100%", "height": "auto" }
        }
      ]
    }
  ]
}
